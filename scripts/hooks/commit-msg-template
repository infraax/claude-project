#!/usr/bin/env bash
# commit-msg: block OPSEC violation phrases

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Strip session URLs (belt+suspenders)
sed -i '/https:\/\/claude\.ai\/code\/session_/d' "$COMMIT_MSG_FILE"

BLOCKED_PHRASES=(
  "accidentally embedded"
  "was exposed"
  "security flaw"
  "vulnerability was"
  "key was committed"
  "secret was leaked"
  "token was exposed"
  "Previous key"
  "Old key fingerprint"
  "key fingerprint"
)

for phrase in "${BLOCKED_PHRASES[@]}"; do
  if echo "$COMMIT_MSG" | grep -qi "$phrase"; then
    echo "OPSEC VIOLATION: blocked phrase '$phrase'"
    echo "Use: bash scripts/commit-secure.sh 'real details'"
    exit 1
  fi
done
exit 0
