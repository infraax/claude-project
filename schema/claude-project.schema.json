{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cdn.jsdelivr.net/npm/claude-project/schema/claude-project.schema.json",
  "title": "Claude Project",
  "description": "Project context file for Claude Code. Works like .git — drop it in any directory to give Claude persistent memory, event logging, agent orchestration, and token-optimized dispatch for that project.",
  "type": "object",
  "required": ["version", "project_id", "name"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URL. Auto-populated by claude-project init."
    },
    "version": {
      "type": "string",
      "enum": ["3", "4", "5", "5.0"],
      "description": "Schema version. '5.0' for projects created with claude-project v5+."
    },
    "project_id": {
      "type": "string",
      "description": "Unique UUID for this project. Generated by claude-project init.",
      "examples": ["a1b2c3d4-e5f6-7890-abcd-ef1234567890"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable project name.",
      "examples": ["VectorBrain", "HomeAutomation", "MyAPI"]
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "One-line description of the project.",
      "examples": ["Persistent AI persona for Anki Vector robot"]
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date the project was initialised.",
      "examples": ["2026-03-20"]
    },
    "created_by": {
      "type": "string",
      "description": "Source label at time of creation — hostname / user.",
      "examples": ["devbox/user", "thinkpad/user", "pi5/pi"]
    },
    "memory_path": {
      "type": "string",
      "description": "Absolute path to the memory directory for this project.",
      "examples": ["~/.claude/projects/my-project/memory"]
    },
    "diary_path": {
      "type": "string",
      "description": "DEPRECATED — use memory_path. Kept for backward compatibility.",
      "deprecated": true
    },
    "stage": {
      "type": "string",
      "description": "Optional current development stage — shown in VS Code status bar.",
      "examples": ["Stage 1 — hardware test", "Milestone 3 — perception layer"]
    },
    "mcp": {
      "type": "object",
      "description": "MCP server overrides for this project. Merged with global ~/.mcp.json.",
      "properties": {
        "servers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "description": "Named sub-agent definitions for this project.",
      "additionalProperties": {
        "type": "object",
        "required": ["role"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "description": "Short description of what this agent does.",
            "examples": ["code-reviewer", "test-runner", "doc-writer"]
          },
          "model": {
            "type": "string",
            "description": "Claude model ID to use for this agent.",
            "examples": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"]
          },
          "backend": {
            "type": "string",
            "enum": ["claude", "ollama", "openai", "local"],
            "description": "Agent backend — defaults to claude."
          },
          "instructions": {
            "type": "string",
            "description": "System prompt / instructions for this agent."
          },
          "tools": {
            "type": "array",
            "description": "MCP tools or built-in tools this agent is allowed to use.",
            "items": { "type": "string" }
          },
          "max_tokens": {
            "type": "integer",
            "description": "Max output tokens for this agent.",
            "minimum": 1
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Arbitrary tags for grouping/filtering agents."
          }
        }
      }
    },
    "services": {
      "type": "object",
      "description": "Named services involved in this project.",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["process", "http", "grpc", "mqtt", "websocket", "other"]
          },
          "url": { "type": "string" },
          "command": { "type": "string" },
          "healthcheck": { "type": "string" },
          "description": { "type": "string" },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "automations": {
      "type": "array",
      "description": "Automation rules: trigger → action pairs.",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "action"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "enabled": { "type": "boolean", "default": true },
          "trigger": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file_change", "schedule", "event", "manual", "dispatch", "service_up", "service_down"]
              },
              "pattern": { "type": "string" },
              "cron": { "type": "string" },
              "event_type": { "type": "string" },
              "service": { "type": "string" }
            }
          },
          "action": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["run_command", "dispatch_agent", "write_event", "send_notification", "call_webhook"],
                "description": "sync_obsidian REMOVED — use CLAUDE_OBSIDIAN_VAULT env var + claude-project sync."
              },
              "command": { "type": "string" },
              "agent": { "type": "string" },
              "prompt": { "type": "string" },
              "event_type": { "type": "string" },
              "message": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "Project-local tool definitions.",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string" },
          "description": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "description": "Monitoring and alerting configuration for this project.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "watch_paths": { "type": "array", "items": { "type": "string" } },
        "healthcheck_interval_seconds": { "type": "integer", "minimum": 10, "default": 60 },
        "log_retention_days": { "type": "integer", "minimum": 1, "default": 90 },
        "notify": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "macos_notifications": { "type": "boolean", "default": true },
            "webhook_url": { "type": "string" }
          }
        }
      }
    },
    "optimizations": {
      "type": "object",
      "description": "Token optimization flags for agent dispatches.",
      "additionalProperties": false,
      "properties": {
        "cache_prefix":  { "type": "boolean", "default": true },
        "format_encode": { "type": "boolean", "default": true },
        "clarity_layer": { "type": "boolean", "default": true },
        "llmlingua":     { "type": "boolean", "default": true },
        "pd_registry":   { "type": "boolean", "default": true }
      }
    },
    "telemetry": {
      "type": "object",
      "description": "Anonymous usage telemetry — opt-in only.",
      "additionalProperties": false,
      "properties": {
        "enabled":         { "type": "boolean", "default": false },
        "installation_id": { "type": "string" },
        "opted_in_at":     { "type": "string", "format": "date-time" }
      }
    }
  }
}
